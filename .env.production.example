# ═══════════════════════════════════════
# teacher-exam — Production Environment
# ═══════════════════════════════════════
# Copy to .env.production and fill in real values.
# chmod 600 .env.production

# ── Domains ──
DOMAIN=ujiansd.com
API_DOMAIN=api.ujiansd.com

# ── Google OAuth ──
# Add https://api.ujiansd.com/api/auth/callback/google as an authorized
# redirect URI in Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ── AI provider — anthropic | minimax ──
AI_PROVIDER=anthropic

# ── Claude (when AI_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── MiniMax — Anthropic-compatible API ([docs](https://platform.minimax.io/docs/api-reference/text-anthropic-api)) (when AI_PROVIDER=minimax) ──
# Keep ANTHROPIC_API_KEY set as well if you want PDF generation to continue working.
MINIMAX_API_KEY=
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
AI_MODEL=MiniMax-M2.7
AI_DISCUSSION_MODEL=MiniMax-M2.7-highspeed

# ── PostgreSQL ──
POSTGRES_USER=school_exam
POSTGRES_PASSWORD=
POSTGRES_DB=school_exam
DATABASE_URL=postgresql://school_exam:POSTGRES_PASSWORD@db:5432/school_exam

# ── Build metadata (optional) ──
VITE_APP_VERSION=1.0.0
VITE_BUILD_ID=prod
