# ═══════════════════════════════════════
# teacher-exam — Production Environment
# ═══════════════════════════════════════
# Copy to .env.production and fill in real values.
# chmod 600 .env.production

# ── Domains ──
DOMAIN=ujiansd.com
API_DOMAIN=api.ujiansd.com

# ── Google OAuth ──
# Add https://api.ujiansd.com/api/auth/callback/google as an authorized
# redirect URI in Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ── AI (Anthropic Claude) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL ──
POSTGRES_USER=school_exam
POSTGRES_PASSWORD=
POSTGRES_DB=school_exam
DATABASE_URL=postgresql://school_exam:POSTGRES_PASSWORD@db:5432/school_exam

# ── Build metadata (optional) ──
VITE_APP_VERSION=1.0.0
VITE_BUILD_ID=prod
