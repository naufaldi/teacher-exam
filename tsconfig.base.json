{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/refs/heads/main/schema.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "floatingEffect": "error",
          "missingStarInYieldEffectGen": "error",
          "globalConsoleInEffect": "error",
          "globalFetchInEffect": "error",
          "tryCatchInEffectGen": "warning",
          "missedPipeableOpportunity": "warning",
          "unnecessaryFailYieldableError": "off",
          "leakingRequirements": "warning"
        },
        "includeSuggestionsInTsc": false,
        "ignoreEffectWarningsInTscExitCode": true
      }
    ],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  }
}
