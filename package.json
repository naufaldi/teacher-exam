{
  "name": "teacher-exam",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:kill": "node scripts/kill-dev-ports.mjs",
    "dev": "pnpm dev:kill && pnpm --parallel --filter @teacher-exam/api --filter @teacher-exam/web run dev",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@teacher-exam/db",
    "db:migrate": "turbo run db:migrate --filter=@teacher-exam/db",
    "db:seed:dev": "pnpm --filter @teacher-exam/api db:seed:dev",
    "type-check": "turbo run type-check",
    "ci:web": "pnpm --filter @teacher-exam/web build && pnpm --filter @teacher-exam/web test",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "effect": "3.21.2"
    }
  }
}
