{
  "name": "teacher-exam",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:kill": "node scripts/kill-dev-ports.mjs",
    "dev": "pnpm dev:kill && pnpm --parallel --filter @teacher-exam/api --filter @teacher-exam/web run dev",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@teacher-exam/db",
    "db:migrate": "turbo run db:migrate --filter=@teacher-exam/db",
    "db:seed:dev": "pnpm --filter @teacher-exam/api db:seed:dev",
    "type-check": "turbo run type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "effect:check": "node scripts/check-effect-style.mjs",
    "ci": "pnpm lint && pnpm effect:check && pnpm type-check && turbo run test",
    "ci:web": "pnpm --filter @teacher-exam/web build && pnpm --filter @teacher-exam/web test",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "effect": "3.21.2"
    }
  }
}
