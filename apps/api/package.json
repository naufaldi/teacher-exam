{
  "name": "@teacher-exam/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --watch --import tsx/esm src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "curriculum:extract": "node --env-file-if-exists=../../.env --import tsx/esm scripts/extract-curriculum.ts",
    "qa:samples": "node --env-file-if-exists=../../.env --import tsx/esm scripts/qa-generate-samples.ts",
    "qa:phase1": "node --env-file-if-exists=../../.env --import tsx/esm scripts/qa-phase1-sampling.ts",
    "db:seed:dev": "node --env-file-if-exists=../../.env --import tsx/esm scripts/seed-dev-guru.ts"
  },
  "dependencies": {
    "@effect/ai": "^0.35.0",
    "@effect/ai-anthropic": "^0.25.0",
    "@effect/ai-openai": "^0.39.2",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "0.51.1",
    "@effect/sql-drizzle": "0.50.0",
    "@effect/sql-pg": "0.52.1",
    "@effect/vitest": "^0.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@teacher-exam/db": "workspace:*",
    "@teacher-exam/shared": "workspace:*",
    "better-auth": "^1.6.6",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "katex": "^0.16.45",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
