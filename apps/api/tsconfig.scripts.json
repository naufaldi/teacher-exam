{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "floatingEffect": "error",
          "missingStarInYieldEffectGen": "error",
          "globalConsoleInEffect": "off",
          "globalFetchInEffect": "error",
          "tryCatchInEffectGen": "warning",
          "missedPipeableOpportunity": "warning",
          "unnecessaryFailYieldableError": "off",
          "leakingRequirements": "warning"
        },
        "includeSuggestionsInTsc": false,
        "ignoreEffectWarningsInTscExitCode": true
      }
    ]
  },
  "include": ["scripts"],
  "exclude": ["scripts/**/__test__/**"]
}
