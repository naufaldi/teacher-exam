# ═══════════════════════════════════════
# School Exam Generator — Environment Example
# ═══════════════════════════════════════
#
# Copy to .env and fill in real values.
# Start Postgres (Docker):
#   docker run --name school-exam-pg \
#     -e POSTGRES_USER=school_exam \
#     -e POSTGRES_PASSWORD=change-me \
#     -e POSTGRES_DB=school_exam \
#     -p 5432:5432 -d postgres:16-alpine
# Then: pnpm db:migrate
# Run: pnpm dev
#

# ── Google OAuth ──
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: ${APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ── AI (Anthropic Claude) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL ──
POSTGRES_USER=school_exam
POSTGRES_PASSWORD=change-me
POSTGRES_DB=school_exam

# ── Application ──
DATABASE_URL=postgresql://school_exam:change-me@localhost:5432/school_exam
UPLOAD_DIR=./uploads
API_PORT=3001
WEB_PORT=3000
APP_URL=http://localhost:3000

# Production:
# APP_URL=https://ujiansd.com

# ── Web (Vite) ──
# Leave VITE_API_URL unset locally so /api uses same-origin proxy → API_PORT
# VITE_API_URL=http://localhost:3001
VITE_APP_ORIGIN=http://localhost:3000
VITE_APP_VERSION=0.0.1
VITE_BUILD_ID=dev
# Set to "1" to bypass Google login locally and run with a stub user.
# Default behaviour (unset / "0") exercises the real OAuth flow.
VITE_AUTH_BYPASS=0

# ── Domain (Caddy auto-SSL) ──
DOMAIN=ujiansd.com
