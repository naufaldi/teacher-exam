# ═══════════════════════════════════════
# School Exam Generator — Environment Example
# ═══════════════════════════════════════
#
# Copy to .env and fill in real values.
# Start Postgres (Docker):
#   docker run --name school-exam-pg \
#     -e POSTGRES_USER=school_exam \
#     -e POSTGRES_PASSWORD=change-me \
#     -e POSTGRES_DB=school_exam \
#     -p 5432:5432 -d postgres:16-alpine
# Then: pnpm db:migrate
# Run: pnpm dev
#

# ── Dev login (local only — never set in production) ──
# DEV_AUTH_ENABLED=true
# DEV_AUTH_EMAIL=dev@guru.local
# DEV_AUTH_PASSWORD=change-me-dev-only
# VITE_DEV_AUTH=true
# DEV_SIMULATE_SALVAGE=1   # API: 24 valid + 1 invalid on generate (no MiniMax); local QA only

# ── Google OAuth ──
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI (local): http://localhost:${API_PORT}/api/auth/callback/google
# Authorized redirect URI (production): https://${API_DOMAIN}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ── AI provider — set to `anthropic` (Anthropic Claude) or `minimax` (MiniMax M2.7 via Anthropic-compatible API) ──
AI_PROVIDER=anthropic

# ── Claude (Anthropic Messages API on api.anthropic.com) — when AI_PROVIDER=anthropic ──
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── MiniMax — Anthropic-compatible Messages API ([docs](https://platform.minimax.io/docs/api-reference/text-anthropic-api)) — when AI_PROVIDER=minimax ──
# Copy-paste setup: set AI_PROVIDER=minimax, paste MINIMAX_API_KEY, keep ANTHROPIC_API_KEY for PDF generation.
MINIMAX_API_KEY=sk-api-REPLACE_ME
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
AI_MODEL=MiniMax-M2.7
AI_DISCUSSION_MODEL=MiniMax-M2.7-highspeed
# Penjaga Kurikulum validation also uses AI_DISCUSSION_MODEL (same provider as pembahasan).
# When local DNS cannot resolve api.minimax.io, keep MINIMAX_DNS_FALLBACK enabled (default).
# Set MINIMAX_DNS_FALLBACK=false to disable Google DNS fallback.
# MINIMAX_DNS_FALLBACK=true
# Optional: set to 1 or true to log successful AI request timing; failures always log as [ai] warn.
# Auto-enabled when DEV_AUTH_ENABLED=true or NODE_ENV=development.
AI_LOG=1

# Offline curriculum PDF → markdown only: apps/api/scripts/extract-curriculum.ts ignores AI_PROVIDER —
# set ANTHROPIC_API_KEY (Claude on api.anthropic.com); that path is still Anthropic-only.

# ── PostgreSQL ──
POSTGRES_USER=school_exam
POSTGRES_PASSWORD=change-me
POSTGRES_DB=school_exam

# ── Application ──
DATABASE_URL=postgresql://school_exam:change-me@localhost:5432/school_exam
UPLOAD_DIR=./uploads
# API listens on :3000 by default; web listens on :5173.
API_PORT=3000
WEB_PORT=5173
# Web app origin, used for CORS and better-auth trustedOrigins.
APP_URL=http://localhost:5173
# Optional locally; when unset, better-auth resolves this to http://localhost:${API_PORT}.
# BETTER_AUTH_URL=http://localhost:3000

# Production:
# APP_URL=https://ujiansd.com
# API_DOMAIN=api.ujiansd.com

# ── Web (Vite) ──
# Leave VITE_API_URL unset locally so /api uses same-origin proxy → API_PORT
# VITE_API_URL=http://localhost:3000
VITE_APP_ORIGIN=http://localhost:5173
VITE_APP_VERSION=0.0.1
VITE_BUILD_ID=dev

# ── Domain (Caddy auto-SSL) ──
DOMAIN=ujiansd.com
